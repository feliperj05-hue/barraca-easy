# Barraca Easy — ambiente de PRODUCAO
#
# Copie para .env.production e preencha com as chaves do projeto Supabase
# de PRODUCAO. Usado por: npm run build / npm run build:production.
#
# .env.production NAO e versionado (ver .gitignore). Somente placeholders
# (*.example) vao ao repo. A publishable key e publica por design
# (client-side, protegida por RLS); ainda assim, injete por env, nunca no codigo.
# NUNCA use aqui a service_role key (secreta, server-side).

VITE_SUPABASE_URL=https://SEU-REF-PRODUCAO.supabase.co
VITE_SUPABASE_PUBLISHABLE_KEY=sb_publishable_xxxxxxxxxxxxxxxxxxxxxxxx
